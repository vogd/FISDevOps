        </mxCell>
        <mxCell id="s3-subtitle" value="Lambda: fis-chaos-scorer | Python 3.12 | 120s timeout&#xa;Deployed: us-west-2 ONLY — NOT cross-regional" style="text;html=1;fontSize=10;align=center;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1130" y="105" width="430" height="35" as="geometry" />
        </mxCell>

        <!-- Lambda -->
        <mxCell id="lambda" value="λ Lambda&#xa;fis-chaos-scorer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=#C45400;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="160" width="150" height="55" as="geometry" />
        </mxCell>

        <!-- S3 -->
        <mxCell id="s3" value="S3 Bucket&#xa;fis-chaos-results-{acct}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3F8624;strokeColor=#2D6B19;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1370" y="160" width="175" height="55" as="geometry" />
        </mxCell>

        <!-- READS box -->
        <mxCell id="reads" value="READS from S3:&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Path: experiments/{id}/{incident}.json&#xa;&#xa;Fields read:&#xa;• name, experiment (type)&#xa;• ground_truth (e.g. &quot;cpu_pressure&quot;)&#xa;• description (FIS template desc)&#xa;• devops_agent_rca (full markdown)&#xa;• agent_rca_snippet (first 120 chars)&#xa;• chaos_kind (PodChaos, NetworkChaos...)&#xa;• fis_status, ts_experiment_started&#xa;• ts_rca_completed, errors[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=9;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1050" y="240" width="260" height="210" as="geometry" />
        </mxCell>

        <!-- WRITES box -->
        <mxCell id="writes" value="WRITES to S3:&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Path: scorecards/latest.json&#xa;&#xa;Structure:&#xa;{&#xa;  total: N,&#xa;  correct: N,  (opus_score=&quot;yes&quot;)&#xa;  partial: N,  (opus_score=&quot;partially&quot;)&#xa;  wrong: N,    (opus_score=&quot;no&quot;)&#xa;  results: [{&#xa;    experiment, name, opus_score,&#xa;    opus_reasoning, ground_truth,&#xa;    devops_agent_rca_full, ...&#xa;  }]&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=9;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="1370" y="240" width="260" height="250" as="geometry" />
        </mxCell>

        <!-- Bedrock (from Lambda) -->
