        <!-- Model config -->
        <mxCell id="model-cfg" value="Model Configuration:&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Model ID: us.anthropic.claude-sonnet-4-6&#xa;Type: Cross-Region Inference Profile&#xa;  → AWS routes to available US capacity&#xa;  → us-east-1, us-west-2, etc.&#xa;&#xa;Region (SDK client): us-west-2&#xa;anthropic_version: bedrock-2023-05-31&#xa;max_tokens: 256" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=10;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="770" y="235" width="195" height="165" as="geometry" />
        </mxCell>

        <!-- Prompt design -->
        <mxCell id="prompt-design" value="Prompt Design (OPUS_PROMPT):&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Persona: Expert SRE evaluator&#xa;• 10 failure category definitions:&#xa;   pod_failure, container_failure,&#xa;   network_latency, network_packet_loss,&#xa;   network_partition, cpu_pressure,&#xa;   memory_pressure, io_latency,&#xa;   http_fault, dns_failure&#xa;• Symptom vs Root Cause distinction enforced&#xa;• Examples of CORRECT vs WRONG diagnosis&#xa;• &quot;Ignore injection tool (Chaos Mesh/FIS)&quot;&#xa;• &quot;CloudTrail/FIS trace = valid finding&quot;&#xa;• JSON output: {score, reasoning}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="470" y="310" width="270" height="230" as="geometry" />
        </mxCell>

