        <!-- ==================== HA BOX ==================== -->
        <mxCell id="ha-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;strokeWidth=2;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="30" y="640" width="1740" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ha-title" value="HA / Cross-Regional Status" style="text;html=1;fontSize=14;fontStyle=1;align=left;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="50" y="650" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ha-details" value="• Model ID &quot;us.anthropic.claude-sonnet-4-6&quot; = Cross-Region Inference Profile&#xa;  → AWS automatically routes InvokeModel to available capacity across US regions (us-east-1, us-west-2, etc.)&#xa;&#xa;• Bedrock SDK client: us-west-2 (single endpoint) — but actual inference is cross-regional under the hood&#xa;&#xa;• Lambda scorer: deployed in us-west-2 ONLY — not replicated to secondary region&#xa;&#xa;• S3 bucket: single region (us-west-2) — Agent Skills in BOTH agent regions (us-east-1 &amp; us-west-2) read cross-region&#xa;&#xa;• Scoring is NOT fully HA: if us-west-2 Lambda/Bedrock unavailable → scoring halts&#xa;  BUT: Investigation IS HA (EventBridge Global Endpoint + multi-region agents) — scoring is a non-critical post-process" style="text;html=1;fontSize=10;align=left;fontColor=#455A64;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="680" width="1700" height="150" as="geometry" />
        </mxCell>

