        <mxCell id="prompt-in" value="Prompt Inputs:&#xa;━━━━━━━━━━━━━━━━━━━━━━&#xa;• experiment_name (from experiments.json)&#xa;• ground_truth (e.g. &quot;cpu_pressure&quot;)&#xa;• description (FIS template description,&#xa;   e.g. &quot;Spike CPU to 100% on app pods&quot;)&#xa;• agent_rca (first 3000 chars of&#xa;   investigation_summary_md)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="470" y="150" width="280" height="140" as="geometry" />
