        <mxCell id="flow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2.5;fontSize=10;fontStyle=1;" edge="1" source="out2" target="lambda" parent="1" value="batch mode →">
