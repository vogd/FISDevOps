<mxfile host="app.diagrams.net" modified="2026-05-21T19:55:00.000Z">
  <diagram name="Scoring Pipeline" id="scoring-pipeline">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Scoring Pipeline — Three-Stage RCA Evaluation" style="text;html=1;fontSize=20;fontStyle=1;align=center;fontFamily=Arial;" vertex="1" parent="1">
          <mxGeometry x="500" y="15" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- ==================== STAGE 1 BOX ==================== -->
        <mxCell id="s1-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;strokeWidth=2.5;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="380" height="370" as="geometry" />
        </mxCell>
        <mxCell id="s1-title" value="① Keyword Match (instant)" style="text;html=1;fontSize=15;fontStyle=1;align=center;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="70" y="80" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="s1-subtitle" value="In-process (orchestrator.py)&#xa;No network call — runs inline after RCA fetch" style="text;html=1;fontSize=10;align=center;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="105" width="280" height="35" as="geometry" />
        </mxCell>

        <!-- Orchestrator -->
        <mxCell id="orch" value="Orchestrator&#xa;(Python)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ED7100;strokeColor=#C45400;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="55" y="155" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Ground truth input -->
        <mxCell id="gt" value="ground_truth&#xa;(from experiments.json)&#xa;e.g. &quot;cpu_pressure&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="215" y="155" width="175" height="55" as="geometry" />
        </mxCell>

        <!-- Agent RCA input -->
        <mxCell id="rca-input" value="agent_rca&#xa;(investigation_summary_md&#xa;from DevOps Agent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="225" width="175" height="55" as="geometry" />
        </mxCell>

        <!-- Logic box -->
        <mxCell id="logic" value="score_rca() logic:&#xa;━━━━━━━━━━━━━━━━━━━&#xa;gt_keywords = ground_truth.replace('_',' ').split()&#xa;→ e.g. ['cpu', 'pressure']&#xa;&#xa;matched = any(kw in rca.lower() for kw in gt_keywords)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7E57C2;fontSize=9;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="55" y="300" width="300" height="95" as="geometry" />
        </mxCell>

        <!-- Output 1 -->
