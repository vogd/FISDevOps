        <mxCell id="bedrock-svc" value="Amazon Bedrock&#xa;bedrock-runtime&#xa;(InvokeModel API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#01A88D;strokeColor=#007B6B;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="155" width="175" height="60" as="geometry" />
